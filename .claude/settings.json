      "Read(//private/tmp/**)",
      "Bash(osascript:*)",
      "WebFetch(domain:engineering.toggl.com)",
      "Bash(/Users/george/.home-directory/bin/toggl-gaps:*)",
      "Bash(/Users/george/.home-directory/bin/toggl-weekly-summary:*)",
